# ---------------------------------------------------------------------------
# LLM provider switch
# ---------------------------------------------------------------------------
# Which backend to use: claude | gpt | gemini | mock
# If unset, auto-detects from whichever API key below is present
# (priority: claude > gpt > gemini), falling back to `mock`.
STARSAGE_PROVIDER=claude

# Provider API keys — set only the one(s) you use.
ANTHROPIC_API_KEY=           # required when STARSAGE_PROVIDER=claude
OPENAI_API_KEY=              # required when STARSAGE_PROVIDER=gpt
GEMINI_API_KEY=              # required when STARSAGE_PROVIDER=gemini
# GOOGLE_API_KEY=            # accepted as an alias for GEMINI_API_KEY

# ---------------------------------------------------------------------------
# Console settings encryption
# ---------------------------------------------------------------------------
# The web console lets you pick a model and store its API key (via the ⚙ popup).
# That key is encrypted at rest with this secret. If unset, a key is generated and
# persisted to .starsage_secret for local/dev use — but SET THIS IN PRODUCTION so
# the value is stable across container rebuilds (a changed secret makes previously
# stored keys unreadable). Any string works; a urlsafe-base64 32-byte Fernet key
# is ideal. Generate one:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STARSAGE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Model overrides (optional) — defaults shown; override any single tier.
# quality tier -> Generator + Synthesis ; fast tier -> Planner + Critic
# ---------------------------------------------------------------------------
# STARSAGE_CLAUDE_QUALITY=claude-sonnet-5
# STARSAGE_CLAUDE_FAST=claude-haiku-4-5
# STARSAGE_GPT_QUALITY=gpt-4o
# STARSAGE_GPT_FAST=gpt-4o-mini
# STARSAGE_GEMINI_QUALITY=gemini-2.5-pro
# STARSAGE_GEMINI_FAST=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Datastore
# ---------------------------------------------------------------------------
# DATABASE_URL is required — StarSage runs on PostgreSQL. Any standard Postgres
# URL works: local, Docker, Cloud SQL, RDS, Neon, Supabase, etc.
# Percent-encode special characters in the password.
#
# Active default: local Postgres, database "starsage".
#   Create it once:  createdb -U postgres starsage      (or: CREATE DATABASE starsage;)
#   Apply schema:    python src/main.py migrate
DATABASE_URL=postgresql://postgres:root@127.0.0.1:5432/starsage

# Other examples (managed hosts usually need ?sslmode=require):
#   cloud (SSL)  : postgresql://user:pw@HOST:5432/dbname?sslmode=require
#   Supabase     : the direct host db.<ref>.supabase.co is IPv6-only; on IPv4-only
#                  networks (e.g. WSL) use the Session pooler from the dashboard:
#                  postgresql://postgres.<ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:5432/postgres

# Connection-pool / timeout tuning (optional; defaults shown).
# STARSAGE_PG_POOL=5                # max pooled connections
# STARSAGE_PG_POOL_TIMEOUT=20       # seconds to wait for a pooled connection
# STARSAGE_PG_CONNECT_TIMEOUT=12    # seconds per connect attempt (fail fast on bad URL)
